{
	"inputs": [],
	"servers": {
		"playwright": {
			"command": "npx",
			"args": [
				"@playwright/mcp@latest"
			],
			"type": "stdio"
		},
		"playwright-test": {
			"type": "stdio",
			"command": "npx",
			"args": [
				"playwright",
				"run-test-mcp-server"
			]
		},
		"selenium": {
			"type": "stdio",
			"command": "npx",
			"args": [
				"-y",
				"@angiejones/mcp-selenium"
			]
		}
	}
}